{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "ES2020",
      "ES2021",
      "dom",
      "dom.iterable"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "ESNext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": "./src",
    "paths": {
      "@atoms/*": [
        "app/atoms/*"
      ],
      "@molecules/*": [
        "app/molecules/*"
      ],
      "@modules/*": [
        "app/modules/*"
      ],
      "@pages/*": [
        "app/pages/*"
      ],
      "@utils/*": [
        "utils/*"
      ]
    },
    "types": ["vite/client"],
    "typeRoots": ["./node_modules/@types", "./src/types"]

  },
  "include": [
    "src/**/*"
  ]
}